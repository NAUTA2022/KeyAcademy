# ThirdWeb — https://thirdweb.com/dashboard
VITE_THIRDWEB_CLIENT_ID=your_thirdweb_client_id

# Supabase — https://supabase.com/dashboard
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# EmailJS — https://www.emailjs.com/
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_REGISTRATION_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Admin credentials (VITE_ vars se incluyen en el bundle — usa un backend en producción)
VITE_ADMIN_EMAIL=admin@tu-academia.com
VITE_ADMIN_PASSWORD=tu_password_seguro

# ── Payments ──────────────────────────────────────────────────────────────────

# Wallet de la academia que recibe pagos en cripto (dirección en Base chain)
# El usuario conecta su wallet con ThirdWeb y paga USDC/ETH a esta dirección
VITE_ADMIN_WALLET=0xTU_WALLET_AQUI

# Stripe Payment Links
# 1. Ve a https://dashboard.stripe.com/payment-links
# 2. Crea un producto "Plan Cursos" por $10 USD/mes
# 3. En "After payment" configura la URL de éxito: https://tu-app.com/membership?stripe_success=1
# 4. Copia el link aquí
VITE_STRIPE_LINK_COURSES=https://buy.stripe.com/XXXXX

# 1. Crea otro producto "Plan Completo" por $25 USD/mes
# 2. Misma configuración de success URL
VITE_STRIPE_LINK_FULL=https://buy.stripe.com/YYYYY
